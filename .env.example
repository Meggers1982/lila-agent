# .env.example — copy to .env and fill in values.
# See SECRETS_REGISTRY.md for where to get each key.
# NEVER commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Required. Claude Platform API key with Managed Agents beta access.
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────
# Required for image generation (GPT-5.5 / GPT Image 2).
# Org verification required before gpt-image-2 access is granted.
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=

# ── Claude Platform (populated by scripts/deploy.py) ──────────────────────
# Generated on first deploy. Do not edit manually.
CLAUDE_AGENT_ID=
CLAUDE_ENVIRONMENT_ID=

# ── Runtime ───────────────────────────────────────────────────────────────
# Options: development | production
ENVIRONMENT=development

# Max USD spend per agent session (hard cap enforced in config/settings.py)
MAX_BUDGET_USD=25

# MCP server port for local image generation
MCP_IMAGE_SERVER_PORT=8765
